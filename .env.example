# =====================================================================
# ExecutionOS / SkillForge — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.
# =====================================================================

# ── Database ──────────────────────────────────────────────────────────
# Railway/Neon provide this in postgres:// format — the entrypoint
# script converts it to JDBC automatically.
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# Only needed if credentials are NOT embedded in DATABASE_URL
# DATABASE_USERNAME=myuser
# DATABASE_PASSWORD=mypassword

# ── Swagger (now re-enabled but HTTP-Basic-protected, not public) ─────
SWAGGER_USERNAME=admin
SWAGGER_PASSWORD=replace-with-a-strong-password

# ── JWT ───────────────────────────────────────────────────────────────
# REQUIRED. Generate with: openssl rand -hex 32
JWT_SECRET=replace-with-at-least-32-character-random-secret

# ── CORS ──────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=https://your-frontend.vercel.app,https://your-custom-domain.com

# ── Spring ────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── Optional tuning ───────────────────────────────────────────────────
# DB_POOL_SIZE=10
# RATE_LIMIT_CAPACITY=120
# RATE_LIMIT_REFILL_PER_MINUTE=120
# MAX_UPLOAD_BYTES=52428800
# PORT=8080   (set automatically by Railway/Render)

# ── Self-hosted Docker Compose production overlay only ────────────────
# (Not needed for Railway/Render/Neon — only if running
#  docker compose -f docker-compose.yml -f docker-compose.prod.yml up
#  on a VM you manage yourself, using the bundled Postgres container)
# POSTGRES_DB=executionos
# POSTGRES_USER=executionos
# POSTGRES_PASSWORD=replace-with-a-strong-password
# NEXT_PUBLIC_API_URL=/api

# ── Google Sign-In (optional — button only renders when both are set) ──
# Get these from https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com   (frontend, same value)

# ── Email (password resets / invite emails — logs to console if unset) ─
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=SG.xxxxxxxxxx
